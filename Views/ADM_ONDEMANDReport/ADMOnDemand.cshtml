@model GHB_D1.Models.ADMOnDemandViewModel
@{
    Layout = "~/Views/Shared/_LayoutV2.cshtml";
}
@Styles.Render("~/Content/bootstrap.css")
<script>
    $().ready(function () {
        $("#T_DATE").change(function () {
            let d = $(this).val();
            var b = $("#T_DATE").val();
            $("#displayDate").text(d);
            $("#T_DATE").val(d);
            $("#msg").hide();
        })


        $("#searchInput").on("keyup", function () {
            var value = $(this).val().toLowerCase();
            $("#searchTable tr").filter(function () {
                $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
            });
        });

    })
</script>

<style>
    .navbar-inverse {
        background-color: #ff850c;
        border-color: #ff850c;
        min-height: 65px;
    }

        .navbar-inverse .navbar-brand {
            color: #ffffff;
        }

        .navbar-inverse .navbar-nav > li > a {
            color: #ffffff;
        }

    .lbcolor {
        color: orange;
    }

    hr {
        border-top: 1px solid #ff850c;
        border-width: 5px;
    }
</style>


<style>
    /* HTML: <div class="loader"></div> */
    .loader {
        width: 85px;
        aspect-ratio: 1;
        border-radius: 50%;
        border: 8px solid #0000;
        border-right-color: #ff850c;
        position: relative;
        animation: l24 1s infinite linear;
    }

        .loader:before,
        .loader:after {
            content: "";
            position: absolute;
            inset: -8px;
            border-radius: 50%;
            border: inherit;
            animation: inherit;
            animation-duration: 2s;
        }

        .loader:after {
            animation-duration: 4s;
        }

    @@keyframes l24 {
        100% {
            transform: rotate(1turn)
        }
    }
</style>

@using (Html.BeginForm("GenReport", "ADM_ONDEMANDReport", FormMethod.Post, new { autocomplete = "off" }))
{
    <div class="row">
        <div class="col-xs-12 col-sm-12 col-md-2 col-lg-4">
            <h2 class="header-topic" style="color: orange; margin-bottom: 0px;"> @Model.TITLE_REPORT </h2>
            <h5 class="header-topic" style="color: orange; margin-left: 250px; margin-top: 0px;">     REPORTS </h5>
        </div>
        <div class="col-xs-3 col-sm-1 col-md-1 col-lg-1 text-right mg-top-10">
            <label class="ghbFont-color lbtext"> <i class="fa fa-calendar-minus-o"></i> วันที่&nbsp;</label>
        </div>
        <div class="col-xs-9 col-sm-4 col-md-2 col-lg-3">

            <input type="text" name="T_DATE" id="T_DATE" class="form-control rounded-lg lbtext" value="@Model.T_DATE" placeholder="dd/mm/yyyy" />
        </div>
        <div class="col-xs-3 col-sm-1 col-md-2 col-lg-1 text-right mg-top-10">
            <label class="ghbFont-color lbtext"> <i class="fa fa-search"></i> ค้นหา&nbsp;</label>
        </div>
        <div class="col-xs-9 col-sm-4 col-md-3 col-lg-3">
            @Html.TextBoxFor(x => x.SEARCH_KEY, new { @class = "form-control lbtext", @style = "width:15rem;", id = "searchInput", placeholder = "Report name" })
        </div>
        @*<div class="col-xs-12 col-sm-2 col-md-2 col-lg-2 text-left mg-top-10">
                <button id="btnSeach" type="submit" class="btn btn-ghb-primary btn-mg" data-titlereport="@Model.TITLE_REPORT" data-toggle="tooltip" name="cmdButton" title="ค้นหา" value="Search" style="margin-top: 30px; width: 5rem;"> <i class="fa fa-search  fa-color-white"></i>  </button>
            </div>*@
    </div>

    <a onclick="history.back()" title="ย้อนกลับ">
        <i class="fa fa-2x fa-chevron-circle-left" aria-hidden="true" style="cursor:pointer;color:orange;"></i>
    </a>
    <hr />
    <div class="form-row text-right">
        <div class="col-5 col-sm-5 col-md-5 col-lg-5 text-left mn-link-left">
            <a name="titlereport" class="aGHBLink ghbFont-color" style="cursor: pointer; font-size: smaller;" href="@Url.Action("Index","Home")"><i class="fa fa-home fa-color-orange"></i> Home</a>
            <label class="aGHBLink ghbFont-color" style="font-size: smaller;">/</label>
            <label>  ADM_ONDEMAND </label>
        </div>
        <div class="col-7 col-sm-7 col-md-7 col-lg-7 mn-link-right">
            <i class="fa fa-filter fa-color-orange"></i>
            <label class="ghbFont-color" style="font-size: smaller;"> <i class="fab fa-mdb"></i>  กรองตาม </label>
            <label id="displayDate">  @Html.DisplayTextFor(x => x.DISPLAY_FILTER) </label>
            <label>  @Html.DisplayTextFor(x => x.SEARCH_KEY)   </label>
        </div>
    </div>
    @*<div class="form-row text-right">
            <div class="col-12">
                <i class="fa fa-filter fa-color-orange"></i>
                <label class="ghbFont-color" style="font-size: smaller;"> <i class="fab fa-mdb"></i>  กรองตาม </label>
                <label id="displayDate">  @Html.DisplayTextFor(x => x.DISPLAY_FILTER) </label>
                <label>  @Html.DisplayTextFor(x => x.SEARCH_KEY)   </label>
            </div>
        </div>*@

    if (Model.MESSAGE != null && Model.MESSAGE != "")
    {
        <div class="form-row" id="msg">
            <div class="alert alert-danger show" role="alert">
                <strong>แจ้งเตือน</strong> @Model.MESSAGE
                <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
        </div>
    }

    <div class="from-row">
        <div class="col-12">
            <div class="tableFixHead" style="width: 100%; height: 600px;">
                <table style="font: 300 16px 'Tahoma'; color: black; width: auto; " class="table table-bordered table-striped">
                    <thead>
                        <tr>
                            <th style="text-align:center;vertical-align:top;" width="10%" class="ghb-background-color">ลำดับ</th>
                            <th style="text-align:center;vertical-align:top;" width="80%" class="ghb-background-color">ชื่อรายงาน</th>
                            <th style="text-align:center;vertical-align:top;" width="10%" class="ghb-background-color"> PDF Download </th>
                            <th style="text-align:center;vertical-align:top;" width="10%" class="ghb-background-color"> EXCEL Download </th>
                            <th style="text-align:center;vertical-align:top;" width="10%" class="ghb-background-color"> TEXT Download </th>

                        </tr>
                    </thead>
                    <tbody id="searchTable">
                        @foreach (var item in ViewBag.GroupDetailReport)
                        {
                            var idBtnPDF = "btn_" + @item.REPORT_NAME + "_PDF_" + item.ID;
                            var idBtnEXCEL = "btn_" + @item.REPORT_NAME + "_EXCEL_" + item.ID;
                            var idBtnTEXT = "btn_" + @item.REPORT_NAME + "_TEXT_" + item.ID;
                            <tr>
                                <td style="text-align: right;">@item.ID</td>
                                <td style="text-align: left;">@item.REPORT_NAME</td>

                                <td style="text-align: center;">
                                    <button id="btnADMPDF" type="submit" class="btn-ghb-pdf-export" data-toggle="tooltip" name="cmdButton" title="Export PDF File" style="cursor:pointer;" value="@item.REPORT_NAME|1"></button>
                                </td>

                                <td style="text-align: center;">
                                    <button id="btnADMXLS" type="submit" class="btn-ghb-excel-export" data-toggle="tooltip" name="cmdButton" title="Export Excel File" style="cursor:pointer;" value="@item.REPORT_NAME|2"></button>
                                </td>

                                <td style="text-align: center;">
                                    <button id="btnADMTXT" type="submit" class="btn-ghb-text-export" data-toggle="tooltip" name="cmdButton" title="Export Text File" style="cursor:pointer;" value="@item.REPORT_NAME|3"></button>
                                </td>
                            </tr>


                        }
                    </tbody>


                </table>
            </div>
        </div>
    </div>

    @Html.HiddenFor(x => x.TITLE_REPORT)
    @Html.HiddenFor(x => x.USER_ID)
    @Html.HiddenFor(x => x.BRANCH_ID)
    @Html.HiddenFor(x => x.T_DATE)
}











