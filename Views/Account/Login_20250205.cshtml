@using GHB_D1.Models
@model LoginViewModel
@{
    ViewBag.Title = "Log in";
}
@Styles.Render("~/Content/css")
<style>
    body {
        background: #ff850c;
        background: -webkit-linear-gradient(#FFD20B, #ff850c, #ff850c);
        background: linear-gradient(#FFD20B, #ff850c, #ff850c);
    }

    html {
        background-color: unset;
    }

    .loginFont {
        font-size: 20pt;
        font-family: "DBHeaventt-Light";
    }

    .loginWrong {
        font-size: 14pt;
        font-family: "DBHeaventt-Light";
        /*float: left;
        margin-left: 22px;*/
    }

    @@font-face {
        font-family: 'DBHeaventt-Light';
        /*src: url('../ghbrpt/fonts/DBHeaventt-Light.ttf') format('truetype');*/
        /*src: url('~/fonts/DBHeaventt-Light.ttf') format('truetype');*/
        src: url('../DBHeaventt-Light.ttf') format('truetype');
    }

    .center {
        margin: auto;
        padding: 35% 0px 0px 0px;
    }

    .removeBullet ul {
        list-style-type: none;
    }

    .validatUser {
        font-size: 16px;
        /*float: left;
        margin-left: 44px;*/
        margin-bottom: -14px;
    }

    .validatPassowrd {
        font-size: 16px;
        /*float: left;
        margin-left: 44px;*/
    }

    .form-control:focus {
        border-color: #ff850c !important;
    }

    .validfont {
        font-size: 16px;
    }

    .btnCancel {
        border: none;
        color: #fff;
        width: 100%;
        padding: 10px 0;
        text-align: center;
        text-decoration: none;
        display: inline-block;
        text-transform: uppercase;
    }
</style>
@*<div class="row">
        <div class="col-md-4"></div>
        <div class="col-md-8 text-left">
            <h2 class="ghbFont-color" style="margin-top: 50px;">@ViewBag.Title.</h2>
        </div>
    </div>*@
<ul class="circles">
    <li></li>
    <li></li>
    <li></li>
    <li></li>
    <li></li>
    <li></li>
    <li></li>
    <li></li>
    <li></li>
    <li></li>
</ul>
<div class="row center-block">
    @*<div class="col-md-3">&nbsp;</div>*@
    <div class="col-md-12" style="text-align: -webkit-center;">
        <div class="col-sm-3">&nbsp;</div>
        <div class="col-sm-6">
            <div class="wrapper fadeInDown center">
                <div id="formContent" class="loginFont">
                    <!-- Tabs Titles -->
                    <!-- Icon -->
                    <div class="fadeIn first">
                        <img src="~/images/ghb-logo-new_sign.png" class="login-banner" id="GHB-logo-sign" alt="GHB-logo-sign">
                    </div>
                    <div><span class="ghbFont-color" style="font-size:22px;">เข้าระบบ</span></div>
                    <section id="loginForm">
                        @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", role = "form" }))
                        {
                            @Html.AntiForgeryToken()

                            <div class="form-group">
                                @*@Html.LabelFor(m => m.Username, new { @class = "col-md-2 ghbFont-color" })*@
                                <div class="col-md-12">
                                    @Html.ValidationSummary(true, "", new { @class = "text-danger removeBullet loginWrong validfont", style = "margin-left: -44px;" })
                                </div>
                                <div class="col-md-12">
                                    @Html.TextBoxFor(m => m.Username, new { placeholder = "User Name", @class = "form-control ghbFont-color", Style = "font-size:18px;", autocomplete = "off" })
                                    @Html.ValidationMessageFor(m => m.Username, "", new { @class = "text-danger validatUser", Style = "display:block;" })
                                </div>
                            </div>
                            <div class="form-group">
                                @*@Html.LabelFor(m => m.Password, new { @class = "col-md-2 ghbFont-color" })*@
                                <div class="col-md-12">
                                    @Html.PasswordFor(m => m.Password, new { placeholder = "Password", @class = "form-control ghbFont-color", Style = "font-size:18px;", autocomplete = "off" })
                                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger validatPassowrd", Style = "display:block;" })
                                </div>

                            </div>
                            <div class="form-group" style="display:none;">
                                <div class="col-md-12">
                                    <select id="system" name="system" class="form-control ghbFont-color" style="font-size: 18px; display: inline; margin-bottom: 15px;">
                                        <option value="0">โปรดเลือกระบบ</option>
                                        <option value="1">GHB</option>
                                        <option value="2" selected="selected">LOCAL</option>
                                    </select>
                                </div>
                            </div>
                            <div class="form-group">
                                <div class="col-md-12">

                                    @if (ViewBag.ShowPopup == true)
                                    {
                                        @*<input type="submit" id="logagain" name="logagain" value="OK" class="btn btn-ghb-primary fadeIn fifth" style="background-color: #ff850c;" />*@
                                        <div class="col-md-1">&nbsp;</div>
                                        <div class="col-md-5">
                                            <button id="btnSave" type="submit" class="btn btn-ghb-primary" style="font-size:16px;" data-toggle="tooltip" name="cmdButton" title="Save" value="Yes">YES</button>
                                        </div>
                                        <div class="col-md-5">
                                            @*<button id="btnCancel" type="submit" class="btn btn-ghb-primary" data-toggle="tooltip" name="cmdButton" title="Cancel" value="Cancel" style="margin-top: 20px;">NO</button>*@
                                            @Html.ActionLink("NO", "Login", "Account", routeValues: null, htmlAttributes: new { id = "btnCancel", style = "font-size:16px", @class = "btn btn-ghb-primary btnCancel" })
                                        </div>
                                        <div class="col-md-1">&nbsp;</div>
                                    }
                                    else
                                    {
                                        <div style="margin-top:-14px;">
                                            @*@Html.ActionLink("ลืมรหัสผ่าน", "ForgotPassword", routeValues: null, htmlAttributes: new { id = "registerLink", style = "float:left;font-size:18px;margin-left:40px;text-decoration: none; color: #ff850c;" })*@
                                            @*<a href="#" id="forget-password" style="font-size:18px;margin-left:40px;" class="forget-password-btn">ลืมรหัสผ่าน</a>*@
                                            @*<a href="#" id="register-btn" style="font-size: 18px; margin-right: 40px;" class="register-btn">ลงทะเบียน</a><br>*@
                                        </div>
                                        <div class="col-md-12">
                                            @*<div class="col-md-6">
                                                    @Html.ActionLink("ลงทะเบียน(บัญชีทั่วไป)", "Register2", "Account", routeValues: null, htmlAttributes: new { id = "registerLink", style = "font-size:16px;text-decoration: none; color: #ff850c;" })
                                                </div>
                                                <div class="col-md-12">
                                                    @Html.ActionLink("ลงทะเบียน(บัญชีLdap)", "AddUserLDAP2", "Account", routeValues: null, htmlAttributes: new { id = "registerLdap", style = "font-size:16px;text-decoration: none; color: #ff850c;" })
                                                </div>*@
                                        </div>
                                        <input type="submit" value="Log in" class="btn btn-ghb-primary  fifth" style="background-color: #ff850c; margin-top: 4px;" />
                                    }
                                </div>
                            </div>
                            <br />
                        }
                    </section>
                </div>
            </div>
        </div>
        <div class="col-sm-3">&nbsp;</div>
    </div>
    @*<div class="col-md-3">&nbsp;</div>*@
    @*<div class="col-md-4">
            <section id="socialLoginForm">
                @Html.Partial("_ExternalLoginsListPartial", new ExternalLoginListViewModel { ReturnUrl = ViewBag.ReturnUrl })
            </section>
        </div>*@
</div>
<script>
    $(document).ready(function () {
        $("#btnSave").click(function () {
            //$('#loading').show();
        });

        $("#btnCancel").click(function () {
            //$('#loading').show();
        });


    });

</script>
@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}
