<link href="~/Content/mmdb.css" rel="stylesheet" />
<style>
    body {
        background: #ff850c;
        background: -webkit-linear-gradient(#FFD20B, #ff850c, #ff850c);
        background: linear-gradient(#FFD20B, #ff850c, #ff850c);
    }

    html {
        background-color: unset;
    }

    .loginFont {
        font-size: 20pt;
        font-family: "DBHeaventt-Light";
    }

    .loginWrong {
        font-size: 14pt;
        font-family: "DBHeaventt-Light";
        /*float: left;
        margin-left: 22px;*/
    }

    input[type=text]:focus, input[type=password]:focus, input[type=email]:focus, input[type=tel]:focus {
        color: #ff850c;
        background-color: #fff;
        border-bottom: 0px solid #ff850c;
    }

    @@font-face {
        font-family: 'DBHeaventt-Light';
        /*src: url('../ghbrpt/fonts/DBHeaventt-Light.ttf') format('truetype');*/
        /*src: url('~/fonts/DBHeaventt-Light.ttf') format('truetype');*/
        src: url('../DBHeaventt-Light.ttf') format('truetype');
    }

    .center {
        margin: auto;
        padding: 30% 0px 0px 0px;
    }

    .removeBullet ul {
        list-style-type: none;
    }

    .validatUser {
        font-size: 16px;
        /*float: left;
        margin-left: 44px;*/
        margin-bottom: -14px;
    }

    .validatPassowrd {
        font-size: 16px;
        /*float: left;
        margin-left: 44px;*/
    }

    .form-control:focus {
        border-color: #ff850c !important;
    }

    .validfont {
        font-size: 16px;
    }

    .btnCancel {
        border: none;
        color: #fff;
        width: 100%;
        padding: 10px 0;
        text-align: center;
        text-decoration: none;
        display: inline-block;
        text-transform: uppercase;
        background-color: #ff850c;
    }

    .glyphicon2 {
        position: absolute;
        top: 48%;
        -webkit-transform: translateY(-50%);
        -moz-transform: translateY(-50%);
        -ms-transform: translateY(-50%);
        -o-transform: translateY(-50%);
        transform: translateY(-50%);
        font-size: 14px;
        color: #808080;
        right: 8%;
        display: inline;
    }

    #wrap {
        min-height: 100%;
    }

    #main {
        overflow: auto;
        padding-bottom: initial; /* this needs to be bigger than footer height*/
    }

    #footerLogin {
        position: relative;
        margin-top: 2%; /* negative value of footer height */
        /*height: 150px;
        clear: both;
        padding-top: 8%;
        min-height: 100%;*/
    }

    .form-label1 {
        position: absolute;
        top: 0;
        max-width: 90%;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        left: 0.75rem;
        padding-top: 0.37rem;
        pointer-events: none;
        transform-origin: 0 0;
        transition: all 0.2s ease-out;
        color: var(--mdb-form-control-label-color);
        margin-bottom: 0;
    }

    .getLeft {
        margin-left: 4px!important;
    }
