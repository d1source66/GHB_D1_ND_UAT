                                                </div>
                                                <div class="col-md-12">
                                                    @Html.ActionLink("ลงทะเบียน(บัญชีLdap)", "AddUserLDAP2", "Account", routeValues: null, htmlAttributes: new { id = "registerLdap", style = "font-size:16px;text-decoration: none; color: #ff850c;" })
                                                </div>*@
                                        </div>
                                        <input type="submit" id="sublogin" name="sublogin" value="Sing in [ SIT ]" class="btn btn-ghb-primary  fifth" style="background-color: #ff850c; margin-top: 4px;text-transform:initial;font-size:18px;" />
                                    }
                                </div>
                            </div>
                            <br />
                        }
