    <div class="col-md-12">
        <div id="wrap">
            <div id="main" class="container clear-top">
                <p>&nbsp;</p>
            </div>
        </div>
        <section id="footerLogin">
            @Html.Partial("footer", new footerDetails { ftDetails = ViewBag.ftDetails })
        </section>
    </div>
</div>
<script src="~/Scripts/mdb.umd.min.js"></script>
<script>
    $(document).ready(function () {
        $("#sublogin").prop('disabled', true);
        $("#sublogin").css('background-color', '#808080');//#ff850c
        $("#btnSave").click(function () {
            //$('#loading').show();
        });

        $("#btnCancel").click(function () {
            //$('#loading').show();
        });

        // Function to check input and enable/disable button
        function toggleButton() {
            if ($("#Username").val() === "" && $("#Password").val() === "") {
                // If input is empty, disable the button
                $("#sublogin").prop('disabled', true);
                $("#sublogin").css('background-color', '#D3D3D3');
            } else {
                // If input is not empty, enable the button
                $("#sublogin").prop('disabled', false);
                $("#sublogin").css('background-color', '#ff850c');
            }
        }

        // Trigger the function on input change
        $("#Username").on('input', function () {
            toggleButton();
        });
        $("#Password").on('input', function () {
            toggleButton();
        });

        // Initial check to handle case if input is already filled
        toggleButton();

    });

    function togglePassword() {
        const icon = document.querySelector('[class*=glyphicon-eye]');
        if (icon.classList.contains('glyphicon-eye-close'))
            icon.classList.replace('glyphicon-eye-close', 'glyphicon-eye-open');
        else icon.classList.replace('glyphicon-eye-open', 'glyphicon-eye-close');

        const input = document.querySelector('#Password');
        if (input.type === 'password') input.type = 'text';
        else input.type = 'password';
    }

</script>
