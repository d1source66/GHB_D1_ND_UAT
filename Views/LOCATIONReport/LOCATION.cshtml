@using (Html.BeginForm("GenReport", "LOCATIONReport", FormMethod.Post, new { autocomplete = "off" }))
{
    <div class="col-md-12 setNav">
        <a name="" class="setNavFont headPath" href="@Url.Action("Index","Administrator")"><i class="fa fa-home fa-color-orange"></i>หน้าหลัก</a>
        <label class="setNavFont"> / </label>
        <a name="" class="setNavFont headPath" href="@Url.Action("Index","Home")"><i class="fa fa-home fa-color-orange"></i>Details Report</a>
        <label class="setNavFont"> / </label>
        <label class="setNavFont">LOCATION</label>
    </div>
    <div class="setPage ">
        <div class="row g-3 formColor">
            <div class="col-md-12" style="border-bottom: 1px solid #e0e0e0;">
                <div class="col-md-8">
                    <label class="form-label labelForm">Detail Report LOCATION</label>
                </div>
                <div class="col-md-2"></div>
                <div class="col-md-2 setButton1">
                    &nbsp;
                </div>
            </div>
            <div class="col-md-12">&nbsp;</div>
            <div class="col-md-12">
                <div class="col-md-6" style="text-align: end; display: flex; justify-content: flex-end; align-items: center; padding: 5px 18px 5px 0px;">
                    <label class="form-label labelCss" style=" margin-right: 7px;">วันที่เริ่มต้น</label>
                    @*<input type="text" class="form-control" id="departInput" style="width:50%;">*@
                    <div class="input-group date calendar-width ">
                        @Html.TextBox("FrDate", @Model.F_DATE as string, new { @class = "form-control rounded-lg", @placeholder = "dd-mm-yyyy", @indexer = "-1", @style = "margin:0px;border: 1px solid #aaa;width: 204px;", autocomplete = "off" })
                        <span class="input-group-addon" id="iconFr"><i class="glyphicon glyphicon-calendar"></i></span>
                    </div>
                </div>
                <div class="col-md-6" style="display: flex; align-items: center;">
                    <label class="form-label labelCss" style="margin-right: 5px;">วันที่สิ้นสุด</label>
                    @*<input type="text" class="form-control" id="disInput" style="width:50%;">*@
                    <div class="input-group date calendar-width ">
                        @Html.TextBox("ToDate", @Model.T_DATE as string, new { @class = "form-control rounded-lg", @placeholder = "dd-mm-yyyy", @indexer = "-1", @style = "margin:0px;border: 1px solid #aaa;width: 204px;", autocomplete = "off" })
                        <span class="input-group-addon" id="iconTo"><i class="glyphicon glyphicon-calendar"></i></span>
                    </div>
                </div>
            </div>
            <div class="col-md-12">
                &nbsp;
                @if (Model.MESSAGE != null && Model.MESSAGE != "")
                {
                    <div class="form-row" id="msg">
                        <div class="alert alert-danger show" role="alert">
                            <strong>แจ้งเตือน</strong> @Model.MESSAGE
                            <button type="button" class="close" data-dismiss="alert" aria-label="Close" id="cmdClose">
                                <span aria-hidden="true">&times;</span>
                            </button>
                        </div>
                    </div>
                }
            </div>
            <div class="form-row">
                <div class="col-12" style="padding:0px 18px;">
                    <div class="divContainer">
                        <div class="divMain">
                            <div class="div1">
                                <div class="tableFixHead" style="width: 100%;">
                                    <table class="table table-striped display nowrap tblHeader">
                                        <thead>
                                            <tr>
                                                <th style="text-align:center;vertical-align:top;" width="10%" class="ghb-background-color">ลำดับ</th>
                                                <th style="text-align:center;vertical-align:top;" width="80%" class="ghb-background-color">ชื่อรายงาน</th>
                                                @*@if (Model.BRANCH_ID == "001" || Model.BRANCH_ID == "049")
                                                    { }*@
                                                <th style="text-align:center;vertical-align:top;" width="10%" class="ghb-background-color"> PDF Download </th>
                                                <th style="text-align:center;vertical-align:top;display:none;" width="10%" class="ghb-background-color"> EXCEL Download </th>
                                                <th style="text-align: center; vertical-align: top; display: none;" width="10%" class="ghb-background-color"> TEXT Download </th>
                                            </tr>
                                        </thead>
                                        <tbody id="searchTable">
                                            @foreach (var item in ViewBag.GroupDetailReport)
                                            {
                                                var idBtnPDF = "btn_" + @item.REPORT_NAME + "_PDF_" + item.ID;
                                                var idBtnEXCEL = "btn_" + @item.REPORT_NAME + "_EXCEL_" + item.ID;
                                                var idBtnTEXT = "btn_" + @item.REPORT_NAME + "_TEXT_" + item.ID;
                                                <tr>
                                                    <td style="text-align: right; vertical-align: middle;">@item.ID</td>
                                                    <td style="text-align: left; vertical-align: middle;">@item.REPORT_NAME</td>
                                                    @*@if (Model.BRANCH_ID == "001" || Model.BRANCH_ID == "049")
                                                        { }*@
                                                    <td style="text-align: center;">
                                                        <button id="btnADMPDF" type="submit" class="btn-ghb-pdf-export" data-toggle="tooltip" name="cmdButton" title="Export PDF File" style="cursor:pointer;" value="@item.T_TERM_T_TERM_ID|@item.REPORT_NAME|1" data-cmdButton="@item.T_TERM_T_TERM_ID|@item.REPORT_NAME|1"></button>
                                                    </td>
                                                    <td style="text-align: center;display:none;">
                                                        <button id="btnADMXLS" type="submit" class="btn-ghb-excel-export" data-toggle="tooltip" name="cmdButton" title="Export Excel File" style="cursor:pointer;" value="@item.T_TERM_T_TERM_ID|@item.REPORT_NAME|2" data-cmdButton="@item.T_TERM_T_TERM_ID|@item.REPORT_NAME|2"></button>
                                                    </td>
                                                    <td style="text-align: center; display: none;">
                                                        <button id="btnADMTXT" type="submit" class="btn-ghb-text-export" data-toggle="tooltip" name="cmdButton" title="Export Text File" style="cursor:pointer;" value="@item.T_TERM_T_TERM_ID|@item.REPORT_NAME|3" data-cmdButton="@item.T_TERM_T_TERM_ID|@item.REPORT_NAME|3"></button>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>



    @Html.HiddenFor(x => x.TITLE_REPORT)
    @Html.HiddenFor(x => x.USER_ID)
    @Html.HiddenFor(x => x.BRANCH_ID)
}