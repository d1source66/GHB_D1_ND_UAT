@Styles.Render("~/Content/bootstrap.css")

<style>
    .navbar-inverse {
        background-color: #ff850c;
        border-color: #ff850c;
        min-height: 65px;
        /*position: relative;*/
    }

        .navbar-inverse .navbar-brand {
            color: #ffffff;
        }

        .navbar-inverse .navbar-nav > li > a {
            color: #ffffff;
        }

    .logo-header {
        position: relative;
        z-index: 1000;
        display: inline-block;
        margin: 0 auto;
        text-align: center;
    }

        .logo-header .logo-main {
            width: 96px;
            padding: 5px 0;
            /*margin-left: 164%;*/
        }

    .logo-ghb-img {
        vertical-align: middle;
        width: 114%;
    }

    hr {
        border-top: 1px solid #ff850c;
        border-width: 5px;
    }

    /* HTML: <div class="loader"></div> */
    .loader {
        width: fit-content;
        font-weight: bold;
        font-family: monospace;
        font-size: 30px;
        background: linear-gradient(90deg, #ff850c1a 50%, #0000 0) right / 200% 100%;
        animation: l21 2s infinite linear;
    }

        .loader::before {
            content: "Loading...";
            color: #ff850c;
            padding: 0 5px;
            background: inherit;
            background: linear-gradient(90deg, #ff850c1a 50%, #0000 0) right / 200% 100%;
            -webkit-background-clip: text;
            background-clip: text;
        }

    @@keyframes l21 {
        100% {
            background-position: left
        }
    }
</style>

<script>
    $().ready(function () {

        SetDatePickerTop(130);

        $("#T_DATE").change(function () {
            let d = $(this).val();
            var b = $("#T_DATE").val();
            $("#displayDate").text(d);
            $("#T_DATE").val(d);
            $("#msg").hide();
        })

        $("#searchInput").on("keyup", function () {
            var value = $(this).val().toLowerCase();
            $("#searchTable tr").filter(function () {
                $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
            });
        });

    })
</script>



