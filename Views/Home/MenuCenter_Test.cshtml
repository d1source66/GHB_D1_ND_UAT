<script>
    $().ready(function () {





        $("#btnAllDownload").click(function (e) {
            $("#popmsg").hide();
            $("#popmsg-success").hide();
            $("#msg").text("");
            $("#msg-success").text("");


             e.preventDefault();
            $.ajax({
              type: "POST",
                    dataType: "json",
                    data: '{ "branchID" : "' + $("#BRANCH_ID").val() + '", "T_DATE" : "' + $("#T_DATE").val() + '" }',
                    contentType: 'application/json; charset=utf-8',
                    url: '@Url.Action("AllDownload", "Home")', beforeSend: function (xhr) {
                        $("#displayLoading").show();
                    },
                success: function (result) {
                    $("#displayLoading").hide();
                    $("#popmsg-success").hide();
                    if (result.length == 0) {

                    } else {

                        $("#msg-success").text("โหลดข้อมูลรายงานทั้งหมด เรียบร้อยแล้ว สามารถเข้าไปดูรายงานได้ที่ D:\\GHBReportFiles\\");
                        $("#popmsg-success").show();

                    }
                }
                ,
                error: function (xhr, ajaxOptions, thrownError) {
                    $("#displayLoading").hide();
                    $("#msg").text("ไม่สามารถโหลดรายงาน");
                    $("#popmsg").show();
                }

            });
        });


        $('#sandbox-container input').datepicker({
            autoclose: true,
            showWeek: true,
            showOtherMonths: true,
            todayHighlight: true,
            language: 'th-th',
            format: "dd/mm/yyyy",
            endDate: new Date(new Date().setDate(new Date().getDate() - 1)),
            setDate: new Date(new Date().setDate(new Date().getDate() - 1))
        });


        $("#sandbox-container input").change(function () {
            let d = $(this).val();
            var b = $("#sandbox-container").val();
            $("#displayDate").text(d);
            $("#T_DATE").val(d);
            $("#msg").hide();
        })
    })
</script>




@if (Model != null)
{
    string groupName = "";
    <div class="form-row">
        <div class="col-6 col-sm-4 col-md-4 col-lg-4">
            <h2 class="header-topic" style="color: orange; margin-bottom: 0px;"> GHB ALL </h2>
            <h5 class="header-topic" style="color: orange; margin-left: 70px; margin-top: 0px;">     REPORTS  - <span style="font-weight: bold;color: black;"> @Model.BRANCH_NAME  </span> </h5>
        </div>
        <div class="col-6 col-sm-2 col-md-2 col-lg-2 text-right mg-top-20" style="padding-right: 0px;">
            <label class="ghbFont-color" style="padding-top: 5px;">วันที่&nbsp;</label>
        </div>

        <div class="col-6 col-sm-3 col-md-3 col-lg-3 mg-top-20" id="sandbox-container">
            <input type="text" name="T_DATE" id="T_DATE" class="form-control rounded-lg" value="@Model.T_DATE" />
        </div>
        <div class="col-6 col-sm-3 col-md-3 col-lg-3 mg-top-20">
            <button id="btnAllDownload" type="button" class="btn btn-ghb-primary btn-mg" name="cmdButton" value="Download">   <span class="spinner-border spinner-border-sm"></span> <i class="fa fa-download"></i> ALL DOWNLOAD </button>
        </div>
        @*<div class="loader"></div>*@

        <div class="from-row" id="displayLoading" style="display:none;">
            <div class="col-12">
                <div class="loader"></div>
            </div>
        </div>
    </div>

    <hr class="col-6 col-sm-12 col-md-12 col-lg-12">




    <div class="form-row" id="popmsg" style="margin-top: 120px;display:none;">
        <div class="alert alert-danger show" role="alert">
            <div class="row" style="margin-left: 5px; padding-right: 10px;">
                <div class="col-11">
                    <span id="msg"></span>
                    @*<strong>Information</strong> @Model.MESSAGE*@
                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="col-1">

                </div>
            </div>
        </div>
    </div>

    <div class="form-row" id="popmsg-success" style="margin-top: 120px;display:none;">
        <div class="alert alert-success show" role="alert">
            <div class="row" style="margin-left: 5px; padding-right: 10px;">
                <div class="col-11">
                    <span id="msg-success"></span>
                    <button type="button" class="close" data-dismiss="alert" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="col-1">

                </div>
            </div>

        </div>
    </div>


    <div class="navlist-primary">
            @foreach (var m in Model._groupReportVMList)
            {
                string[] typeSpl = m.GROUP_NAME.Split('_');

                if (typeSpl.Length == 1)
                {
                    groupName = @m.GROUP_NAME + "Report";
                    <ul>
                        <li class="active">
                            <div class="row">
                                <div class="col-6 col-sm-10 col-md-10 col-lg-9">
                                    <a name="titlereport" href="@Url.Action("Index", @groupName, new {px = Model.BRANCH_ID,py = Model.USER_ID, pz = @m.GROUP_NAME})">@Html.DisplayFor(d => m.GROUP_NAME)</a>
                                </div>
                                <div class="col-6 col-sm-2 col-md-2 col-lg-3 mg-top-20" style="padding-left: 0px;">
                                    <button id="btnAllType" type="button" class="btn btn-ghb-primary btn-mg" name="cmdButton" value="Download">   <span class="spinner-border spinner-border-sm"></span> <i class="fa fa-download"></i> @Html.DisplayFor(d => m.GROUP_NAME) DOWNLOAD </button>
                                </div>
                            </div>
                        </li>
                    </ul>
                }

            }
        </div>


        <div class="navlist-primary">
            @foreach (var m in Model._groupReportVMList)
            {
                string[] typeSpl = m.GROUP_NAME.Split('_');

                if (typeSpl.Length != 1)
                {
                    groupName = @m.GROUP_NAME + "Report";
                    <ul>
                        <li class="active">
                            <div class="row">
                                <div class="col-6 col-sm-10 col-md-10 col-lg-9">
                                    <a name="titlereport" href="@Url.Action("Index", @groupName, new {px = Model.BRANCH_ID,py = Model.USER_ID, pz = @m.GROUP_NAME})">@Html.DisplayFor(d => m.GROUP_NAME)</a>
                                </div>
                                @*<div class="col-6 col-sm-2 col-md-2 col-lg-3 mg-top-20" style="padding-left: 0px;">
                                    <button id="btnAllTypeOndemand" type="button" class="btn btn-ghb-primary btn-mg" name="cmdButton" value="Download">   <span class="spinner-border spinner-border-sm"></span> <i class="fa fa-download"></i> @Html.DisplayFor(d => m.GROUP_NAME) DOWNLOAD </button>
                                </div>*@
                            </div>
                        </li>
                    </ul>
                }


            }
        </div>


    @Html.HiddenFor(x => x.USER_ID)
    @Html.HiddenFor(x => x.BRANCH_ID)
    @Html.HiddenFor(x => x.T_DATE)

}


<div class="row" id="msg" style="margin-top: 120px;display:none;">
    <div class="alert alert-danger show" role="alert">
        <strong>Information</strong> @Model.MESSAGE
        <button type="button" class="close" data-dismiss="alert" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>
</div>

