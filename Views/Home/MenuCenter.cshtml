<script>
    $().ready(function () {


        $("#btnAllDownload").click(function (e) {
            GenerateReport('#searchTable tr',e);
        });

        SetDatePickerTop(150);

        $("#T_DATE").change(function () {
            let d = $(this).val();
            var b = $("#T_DATE").val();
            $("#displayDate").text(d);
            $("#T_DATE").val(d);
            $("#msg").hide();
        })

        //$('#sandbox-container input').datepicker({
        //    autoclose: true,
        //    showWeek: true,
        //    showOtherMonths: true,
        //    todayHighlight: true,
        //    language: 'th-th',
        //    format: "dd/mm/yyyy",
        //    endDate: new Date(new Date().setDate(new Date().getDate() - 1)),
        //    setDate: new Date(new Date().setDate(new Date().getDate() - 1))
        //});


        //$("#sandbox-container input").change(function () {
        //    let d = $(this).val();
        //    var b = $("#sandbox-container").val();
        //    $("#displayDate").text(d);
        //    $("#T_DATE").val(d);
        //    $("#msg").hide();
        //})




    })

    function GenerateReport(name,e) {

        //$('.groupReport li').each(function () {
        $(name).each(function () {
                var groupNo = $(this).find('.groupNo').val();
                var groupName = $(this).find('.groupName').val();
                var isChecked = $(this).find('.selectItem').is(':checked');
                console.log("isChecked:" + isChecked + " groupNo:" + groupNo + " groupName:" + groupName)
                if (isChecked == 1 && groupNo != undefined) {

                    $("#popmsg").hide();
                    $("#popmsg-success").hide();
                    $("#msg").text("");
                    $("#msg-success").text("");


                    e.preventDefault();
                    $.ajax({
                        type: "POST",
                        dataType: "json",
                        data: '{ "branchID" : "' + $("#BRANCH_ID").val() + '", "T_DATE" : "' + $("#T_DATE").val() + '", "groupNo" : "' + groupNo + '" }',
                        contentType: 'application/json; charset=utf-8',
                        url: '@Url.Action("AllDownload", "Home")', beforeSend: function (xhr) {
                            $("#displayLoading").show();
                        },
                        success: function (result) {
                            $("#displayLoading").hide();
                            $("#popmsg-success").hide();
                            if (result.length == 0) {

                            } else {
                                $("#msg").hide();
                                $("#msg-success").text("โหลดข้อมูลรายงานทั้งหมด เรียบร้อยแล้ว สามารถเข้าไปดูรายงานได้ที่ D:\\GHBReportFiles\\");
                                $("#popmsg-success").show();
                                window.location.href = result.fileUrl;
                            }
                        }
                        ,
                        error: function (xhr, ajaxOptions, thrownError) {
                            $("#displayLoading").hide();
                            $("#msg").text("ไม่สามารถโหลดรายงาน");
                            $("#msg").show();
                            $("#popmsg").show();
                        }

                    });
                }
            });
    }
    function GenerateReport2(groupNo,groupName) {

        //alert("groupNo:" + groupNo + " groupName:" + groupName);

        console.log("groupNo:" + groupNo + " groupName:" + groupName)
                if (groupNo != undefined) {

                    $("#popmsg").hide();
                    $("#popmsg-success").hide();
                    $("#msg").text("");
                    $("#msg-success").text("");


                    //e.preventDefault();
                    $.ajax({
                        type: "POST",
                        dataType: "json",
                        data: '{ "branchID" : "' + $("#BRANCH_ID").val() + '", "T_DATE" : "' + $("#T_DATE").val() + '", "groupNo" : "' + groupNo + '", "groupName" : "' + groupName + '" }',
                        contentType: 'application/json; charset=utf-8',
                        url: '@Url.Action("AllDownload", "Home")', beforeSend: function (xhr) {
                            $("#displayLoading").show();
                        },
                        success: function (result) {
                            $("#displayLoading").hide();
                            $("#popmsg-success").hide();
                            if (result.length == 0) {

                            } else {
                                $("#msg").hide();
                                $("#msg-success").text("โหลดข้อมูลรายงานกลุ่ม " + groupName +" ทั้งหมด เรียบร้อยแล้ว");
                                $("#popmsg-success").show();
                                window.location.href = result.fileUrl;
                            }
                        }
                        ,
                        error: function (xhr, ajaxOptions, thrownError) {
                            $("#displayLoading").hide();
                            $("#msg").text("ไม่สามารถโหลดรายงาน");
                            $("#msg").show();
                            $("#popmsg").show();
                        }

                    });
                }

    }
</script>
<script>
    $(document).ready(function () {
        GetSelectItem(true);
        $('#select-all').click(function () {

            var isChecked = $(this).is(':checked');
            //$('input[type="checkbox"]').each(function () {
            //    $(this).prop('checked', isChecked);
            //});
            GetSelectItem(isChecked);

        });

        $("#searchInput").on("keyup", function () {
            var value = $(this).val().toLowerCase();
            $("#searchTable tr").filter(function () {
                $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
            });
        });
    });

    function GetSelectItem(isChecked) {
        $("#select-all").prop('checked', isChecked);
        $("#searchTable tr:visible .selectItem").prop('checked', isChecked);
    }


  
</script>



