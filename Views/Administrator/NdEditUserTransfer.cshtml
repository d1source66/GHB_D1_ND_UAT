        $("#branchInput1").prop("disabled", true);
        $("#hub_name").prop("disabled", true);
        $("#dept_name").prop("disabled", true);
        $("#Role_Name1").prop("disabled", true);

        $('input[name="_trans"]').change(function () {
            switch ($(this).val()) {
                case "1"://ย้ายสาขา
                    $("#branchInput2").prop("disabled", false);
                    $("#hub_name2").prop("disabled", false);
                    $("#dept_name2").prop("disabled", false);

                    $("#Role_Name2").prop("disabled", true);
                    break;
                case "2"://ย้าย role
                    $("#branchInput2").prop("disabled", true);
                    $("#hub_name2").prop("disabled", true);
                    $("#dept_name2").prop("disabled", true);

                    $("#Role_Name2").prop("disabled", false);
                    break;
                case "3"://ย้ายสาขา ย้าย role
                    $("#Role_Name2").prop("disabled", false);
                    $("#hub_name2").prop("disabled", false);
                    $("#dept_name2").prop("disabled", false);

                    $("#branchInput2").prop("disabled", false);
                    break;
                default:
                    break;
            }
        });

    $('#branchInput1').on('select2:select', function (e) {
            var slt2 = $('#branchInput1').val();
            $.ajax({
                type: "post",
                url: '@Url.Action("NdGetBrandRelation", "Administrator")',
                data: { brandcode: slt2},
                datatype: "json",
                traditional: true,
                success: function (data) {
                    $("#hub_name").attr("value", data.hub_name);
                    $("#hub_code").attr("value", data.hub_code);
                    $("#dept_name").attr("value", data.department_name);
                    $("#dept_code").attr("value", data.department_code);
                }
            });
        });

        $('#branchInput2').on('select2:select', function (e) {
            var slt2 = $('#branchInput2').val();
            $.ajax({
                type: "post",
                url: '@Url.Action("NdGetBrandRelation", "Administrator")',// beforeSend: function (xhr) { waitingDialog.show('กำลังประมวลผล'); },
                data: { brandcode: slt2},
