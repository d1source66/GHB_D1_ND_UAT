                success: function (data) {
                    $("#hub_name2").attr("value", data.hub_name);
                    $("#hub_code2").attr("value", data.hub_code);
                    $("#dept_name2").attr("value", data.department_name);
                    $("#dept_code2").attr("value", data.department_code);
                }
            });
        });

        $("#tbl1").DataTable({
