
@{
    ViewBag.Title = "EditMapUserReport";
    Layout = "~/Views/Shared/_LayoutV2.cshtml";
}


<script type="text/javascript">
    $(function () {
        $('#ID_USER').select2();
        $('#GROUP_NO').select2();
        $('#REPORT_NO').select2();
        $('#ID_BRANCH').select2();
        $('#loading').hide();
        $("#btnSave").click(function () {
            $('#loading').show();
        });
    });
</script>
@if (ViewBag.Message != null)
{
    <script type="text/javascript">
            $(function () {
                alert("@ViewBag.Message");
            });
    </script>
}

<style>
    .navbar-inverse {
        background-color: #ff850c;
        border-color: #ff850c;
        min-height: 65px;
    }

        .navbar-inverse .navbar-brand {
            color: #ffffff;
        }

        .navbar-inverse .navbar-nav > li > a {
            color: #ffffff;
        }

    .lbcolor {
        color: orange;
    }

    hr {
        border-top: 1px solid orange !important;
    }

    #loading {
        position: fixed;
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        opacity: 0.7;
        background-color: #fff;
        z-index: 99;
    }

    #loading-image {
        z-index: 100;
    }
</style>
<div id="loading">
    <img id="loading-image" src="~/images/Spinner-5.gif" alt="Loading..." />
</div>
<div class="row">
    <div class="col-2">
        <table>
            <tr>
                <td colspan="2">
                    <h2 class="header-topic" style="color: orange; margin-bottom: 0px;">Administrator</h2>
                    <h5 class="header-topic" style="color: orange; margin-left: 70px; margin-top: 0px;">EDIT MAP USER REPORT</h5>
                </td>
            </tr>
        </table>
    </div>
</div>

@using (Html.BeginForm("EditMapUserReport", "Administrator", FormMethod.Post))
{
    @Html.Hidden("ID",ViewBag.ID as string)
    <div class="container">
        <div class="row">
            <div class="col-lg-2">
                <label class="ghbFont-color">รหัสผู้ใช้&nbsp;</label>&nbsp;&nbsp;
                @*@Html.TextBox("ID_USER", ViewBag.ID_USER as string, new { @class = "form-control rounded-lg", maxlength = "50" })*@
                <select name="ID_USER" id="ID_USER" class="form-control w-100 rounded-lg">
                    @{
                        <option value="All">โปรดเลือก</option>
                        if (ViewBag.CurrentUserList != "" && ViewBag.CurrentUserList != "All")
                        {
                            char[] _spl = new char[] { '|' };
                            char[] _spf = new char[] { ',' };
                            string[] _arrLine = null;
                            string[] _arrField = null;
                            string Tmpstr = ViewBag.CurrentUserList;
                            string strSel = ViewBag.ID_USER;
                            _arrLine = Tmpstr.Split(_spl);
                            foreach (string str in _arrLine)
                            {
                                _arrField = str.Split(_spf);
                                if (strSel == _arrField[0].ToString())
                                {
                                    <option selected="selected" value="@(_arrField[0].ToString())">@(_arrField[1].ToString())</option>
                                }
                                else
                                {
                                    <option value="@(_arrField[0].ToString())">@(_arrField[1].ToString())</option>
                                }
                            }
                        }
                    }
                </select>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-2">
                <label class="ghbFont-color">รหัสกลุ่ม&nbsp;</label>&nbsp;&nbsp;
                @*@Html.TextBox("GROUP_NO", ViewBag.GROUP_NO as string, new { @class = "form-control rounded-lg", maxlength = "50" })*@
                <select name="GROUP_NO" id="GROUP_NO" class="form-control w-100 rounded-lg">
                    @{
                        <option value="All">โปรดเลือก</option>
                        if (ViewBag.CurrentGroupReportList != "" && ViewBag.CurrentGroupReportList != "All")
                        {
                            char[] _spl = new char[] { '|' };
                            char[] _spf = new char[] { ',' };
                            string[] _arrLine = null;
                            string[] _arrField = null;
                            string Tmpstr = ViewBag.CurrentGroupReportList;
                            string strSel = ViewBag.GROUP_NO;
                            _arrLine = Tmpstr.Split(_spl);
                            foreach (string str in _arrLine)
                            {
                                _arrField = str.Split(_spf);
                                if (strSel == _arrField[0].ToString())
                                {
                                    <option selected="selected" value="@(_arrField[0].ToString())">@(_arrField[1].ToString())</option>
                                }
                                else
                                {
                                    <option value="@(_arrField[0].ToString())">@(_arrField[1].ToString())</option>
                                }
                            }
                        }
                    }
                </select>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-2">
                <label class="ghbFont-color">รหัสรายงาน&nbsp;</label>&nbsp;&nbsp;
                @*@Html.TextBox("REPORT_NO", ViewBag.REPORT_NO as string, new { @class = "form-control rounded-lg", maxlength = "50" })*@
                <select name="REPORT_NO" id="REPORT_NO" class="form-control w-100 rounded-lg">
                    @{
                        <option value="All">โปรดเลือก</option>
                        if (ViewBag.CurrentGroupDetailReportList != "" && ViewBag.CurrentGroupDetailReportList != "All")
                        {
                            char[] _spl = new char[] { '|' };
                            char[] _spf = new char[] { ',' };
                            string[] _arrLine = null;
                            string[] _arrField = null;
                            string Tmpstr = ViewBag.CurrentGroupDetailReportList;
                            string strSel = ViewBag.REPORT_NO;
                            _arrLine = Tmpstr.Split(_spl);
                            foreach (string str in _arrLine)
                            {
                                _arrField = str.Split(_spf);
                                if (strSel == _arrField[0].ToString())
                                {
                                    <option selected="selected" value="@(_arrField[0].ToString())">@(_arrField[1].ToString())</option>
                                }
                                else
                                {
                                    <option value="@(_arrField[0].ToString())">@(_arrField[1].ToString())</option>
                                }
                            }
                        }
                    }
                </select>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-2">
                <label class="ghbFont-color">รหัสสาขา&nbsp;</label>&nbsp;&nbsp;
                @*@Html.TextBox("ID_BRANCH", ViewBag.ID_BRANCH as string, new { @class = "form-control rounded-lg", maxlength = "50" })*@
                <select name="ID_BRANCH" id="ID_BRANCH" class="form-control w-100 rounded-lg">
                    @{
                        <option value="All">โปรดเลือก</option>
                        if (ViewBag.CurrentBranchList != "" && ViewBag.CurrentBranchList != "All")
                        {
                            char[] _spl = new char[] { '|' };
                            char[] _spf = new char[] { ',' };
                            string[] _arrLine = null;
                            string[] _arrField = null;
                            string Tmpstr = ViewBag.CurrentBranchList;
                            string strSel = ViewBag.ID_BRANCH;
                            _arrLine = Tmpstr.Split(_spl);
                            foreach (string str in _arrLine)
                            {
                                _arrField = str.Split(_spf);
                                if (strSel == _arrField[0].ToString())
                                {
                                    <option selected="selected" value="@(_arrField[0].ToString())">@(_arrField[1].ToString())</option>
                                }
                                else
                                {
                                    <option value="@(_arrField[0].ToString())">@(_arrField[1].ToString())</option>
                                }
                            }
                        }
                    }
                </select>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-2">
                <button id="btnSave" type="submit" class="btn btn-ghb-primary" data-toggle="tooltip" name="cmdButton" title="Save" value="Save" style="margin-top: 20px;margin-bottom:20px;">SAVE</button>
                <button id="btnCancel" type="submit" class="btn btn-ghb-primary" data-toggle="tooltip" name="cmdButton" title="Cancel" value="Cancel" style="margin-top: 20px; margin-bottom: 20px;">CANCEL</button>
            </div>
        </div>
    </div>

}