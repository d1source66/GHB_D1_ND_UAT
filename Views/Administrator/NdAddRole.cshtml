                <a href="#" class="uncheckall" style="text-decoration: none;display:none;">Uncheck all</a>
            </div>
        </div>
        <div style="padding:18px;">
            <div class="card-body">
                <table id="tbl1" class="table  table-striped display nowrap" width="100%" style="border: 1px solid #aaa; border-radius: 13px; overflow: hidden; ">
                    <thead>
                        <tr>
                            <th style="text-align:center;vertical-align:top;" width="10%" class="ghb-background-color">No</th>
                            <th style="text-align:center;vertical-align:top;" width="40%" class="ghb-background-color">Module</th>
                            <th style="text-align:center;vertical-align:top;" width="10%" class="ghb-background-color">All</th>
                            <th style="text-align:center;vertical-align:top;" width="10%" class="ghb-background-color">List</th>
                            <th style="text-align:center;vertical-align:top;" width="10%" class="ghb-background-color">Create</th>
                            <th style="text-align:center;vertical-align:top;" width="10%" class="ghb-background-color">View</th>
                            <th style="text-align:center;vertical-align:top;" width="10%" class="ghb-background-color">Update</th>
                            <th style="text-align:center;vertical-align:top;" width="10%" class="ghb-background-color">Delete</th>
                            <th style="text-align:center;vertical-align:top;" width="10%" class="ghb-background-color">Export</th>
                            <th style="text-align:center;vertical-align:top;" width="10%" class="ghb-background-color"></th>
                        </tr>
                    </thead>
                    <tbody id="searchTable">
                        @{
                            int a = 1;
                        }
                        @for (int i = 0; i < Model.Count; i++)
                        {
                            if (Model[i].Module_No.Length < 2 && Model[i].Module_No.Contains("6") == false)//1-5 Roles
                            {
                                <tr>
                                    <th style="text-align: center;font-weight:400;">@Html.DisplayFor(m => Model[i].Module_No)</th>
                                    <th style="text-align: left; font-weight: 400;">@Html.DisplayFor(m => Model[i].Module_Name)</th>
                                    <th style="text-align: center;">@Html.CheckBoxFor(m => Model[i].IsSelected, new { @class = "check_row", @id = @Model[i].Group_Report })</th>
                                    <th style="text-align: center;">@Html.CheckBoxFor(m => Model[i].List_Role, new { @name = "permissions[]", @class = @Model[i].Group_Report + " " + @Model[i].Group_No + " List_Role" })</th>
                                    <th style="text-align: center;">@Html.CheckBoxFor(m => Model[i].Create_Role, new { @name = "permissions[]", @class = @Model[i].Group_Report + " " + @Model[i].Group_No + " Create_Role" })</th>
                                    <th style="text-align: center;">@Html.CheckBoxFor(m => Model[i].View_Role, new { @name = "permissions[]", @class = @Model[i].Group_Report + " " + @Model[i].Group_No + " View_Role" })</th>
                                    <th style="text-align: center;">@Html.CheckBoxFor(m => Model[i].Update_Role, new { @name = "permissions[]", @class = @Model[i].Group_Report + " " + @Model[i].Group_No + " Update_Role" })</th>
                                    <th style="text-align: center;">@Html.CheckBoxFor(m => Model[i].Delete_Role, new { @name = "permissions[]", @class = @Model[i].Group_Report + " " + @Model[i].Group_No + " Delete_Role" })</th>
                                    <th style="text-align: center;">@Html.CheckBoxFor(m => Model[i].Export_Role, new { @name = "permissions[]", @class = @Model[i].Group_Report + " " + @Model[i].Group_No + " Export_Role" })</th>
                                    <th style="text-align: center;"></th>
                                </tr>
                            }
                            if (Model[i].Module_No == "6" && a == 1)
                            {
                                //เพิ่มแถวหัวข้อ จัดการ Report
                                <tr>
                                    <td style="text-align: center;">@Html.DisplayFor(m => Model[i].Module_No)</td>
                                    <td style="text-align: left;">จัดการ Report</td>
                                    <td style="text-align: center;"></td>
                                    <td style="text-align: center;"></td>
                                    <td style="text-align: center;"></td>
                                    <td style="text-align: center;"></td>
                                    <td style="text-align: center;"></td>
                                    <td style="text-align: center;"></td>
                                    <td style="text-align: center;"></td>
                                    <td style="text-align: center;"></td>
                                </tr>
                                a++;
                            }
                            if (Model[i].Module_No == "6" && a > 1)
                            {
                                //ทุกสาขา เฉพาะสาขา
                                <tr>
                                    <th style="text-align: center;"></th>
                                    <th style="text-align: left;">- @Html.DisplayFor(m => Model[i].Module_Name)</th>
                                    <th style="text-align: center;">@Html.CheckBoxFor(m => Model[i].IsSelected, new { @class = "check_row", @id = @Model[i].Group_Report })</th>
                                    <th style="text-align: center;">@Html.CheckBoxFor(m => Model[i].List_Role, new { @name = "permissions[]", @class = @Model[i].Group_Report + " " + @Model[i].Group_No + " List_Role" })</th>
                                    <th style="text-align: center;"></th>
                                    <th style="text-align: center;">@Html.CheckBoxFor(m => Model[i].View_Role, new { @name = "permissions[]", @class = @Model[i].Group_Report + " " + @Model[i].Group_No + " View_Role" })</th>
                                    <th style="text-align: center;"></th>
                                    <th style="text-align: center;"></th>
                                    <th style="text-align: center;">@Html.CheckBoxFor(m => Model[i].Export_Role, new { @name = "permissions[]", @class = @Model[i].Group_Report + " " + @Model[i].Group_No + " Export_Role" })</th>
                                    <th style="text-align: center;"></th>
                                </tr>
                            }
                            else
                            {
                                if (Model[i].Module_No.Length == 3)//Report Head
                                {
                                    //var getid = @Model[i].Module_Name.ToString() + @Model[i].Module_No.ToString() + "IsSelected";
                                    //var getid1 = @Model[i].Module_Name.ToString() + @Model[i].Module_No.ToString() + "List_Role";

                                    <tr>
                                        <td style="text-align: center;">@Html.DisplayFor(m => Model[i].Module_No)</td>
                                        <td style="text-align: left;">@Html.DisplayFor(m => Model[i].Module_Name)<span style="float:right;">ทั้งหมด</span></td>
                                        <td style="text-align: center;">@Html.CheckBoxFor(m => Model[i].IsSelected, new { @class = "columnIsSelected " + @Model[i].Group_No + " " + @Model[i].Module_Name, @id = @Model[i].Group_Report })</td>
                                        <td style="text-align: center;">@Html.CheckBoxFor(m => Model[i].List_Role, new { @class = "columnList_Role " + @Model[i].Group_No + " " + @Model[i].Module_Name, @id = @Model[i].Group_Report })</td>
                                        <td style="text-align: center;"></td>
                                        <td style="text-align: center;">@Html.CheckBoxFor(m => Model[i].View_Role, new { @class = "columnView_Role " + @Model[i].Group_No + " " + @Model[i].Module_Name, @id = @Model[i].Group_Report })</td>
                                        <td style="text-align: center;"></td>
                                        <td style="text-align: center;"></td>
                                        <td style="text-align: center;">@Html.CheckBoxFor(m => Model[i].Export_Role, new { @class = "columnExport_Role " + @Model[i].Group_No + " " + @Model[i].Module_Name, @id = @Model[i].Group_Report })</td>
                                        <td style="text-align: center;"><span id="sh" class="@Model[i].Group_Report" style="cursor:pointer;"><i class="bx bx-down-arrow-alt"></i></span></td>
                                    </tr>
                                }
                                else if (Model[i].Module_No.Length > 3)//Report Details
                                {
                                    <tr class="row @Model[i].Group_Report">
                                        <td style="text-align: center;">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;@Html.DisplayFor(m => Model[i].Module_No)</td>
                                        <td style="text-align: left;">&nbsp;&nbsp;&nbsp;&nbsp;@Html.DisplayFor(m => Model[i].Module_Name)</td>
                                        <td style="text-align: center;">@Html.CheckBoxFor(m => Model[i].IsSelected, new { @class = @Model[i].Group_Report + " IsSelected " + @Model[i].Group_No + " " + @Model[i].Module_Name + " check_row" })</td>
                                        <td style="text-align: center;">@Html.CheckBoxFor(m => Model[i].List_Role, new { @class = @Model[i].Group_Report + " List_Role " + @Model[i].Group_No + " " + @Model[i].Module_Name + " " + @Model[i].Group_Module })</td>
                                        <td style="text-align: center;"></td>
                                        <td style="text-align: center;">@Html.CheckBoxFor(m => Model[i].View_Role, new { @class = @Model[i].Group_Report + " View_Role " + @Model[i].Group_No + " " + @Model[i].Module_Name + " " + @Model[i].Group_Module })</td>
                                        <td style="text-align: center;"></td>
                                        <td style="text-align: center;"></td>
                                        <td style="text-align: center;">@Html.CheckBoxFor(m => Model[i].Export_Role, new { @class = @Model[i].Group_Report + " Export_Role " + @Model[i].Group_No + " " + @Model[i].Module_Name + " " + @Model[i].Group_Module })</td>
                                        <td style="text-align: center;"></td>
                                    </tr>
                                }

                            }
                        }
                    </tbody>
                </table>
                <div class="row">
                    <div class="col-md-12">
                        <div class="col-md-4">&nbsp;</div>
                        <div class="col-md-4" style="display:flex;">
                            <button id="btnSave" type="submit" class="btn btn-ghb-primary" data-toggle="tooltip" name="cmdButton" title="Save" value="Save" style="margin: 20px;margin-bottom: 20px;">SAVE</button>
                            <button id="btnCancel" type="submit" class="btn btn-ghb-primary" data-toggle="tooltip" name="cmdButton" title="Cancel" value="Cancel" style="margin: 20px; margin-bottom: 20px;">CANCEL</button>
                        </div>
                        <div class="col-md-4">&nbsp;</div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>



<script>
    $(function () {
        $('#loading').hide();


        //$("#searchInput").on("keyup", function () {
        //    var value = $(this).val().toLowerCase();
        //    $("#searchTable tr").filter(function () {
        //        $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
        //    });
        //});

        var table = $("#tbl1").DataTable({
            "bFilter": false,
            "bInfo": false,
            "paging": false,
            "ordering": false,
            "info": false,
            select: {
                selector: 'td:not(:nth-child(2))',
            }
        });

        //all checked**********************
        $('#check_all').click(function () {
            $('input').prop('checked', this.checked);
        });
        //all uncheck
        $('.uncheckall').click(function () {
            $('input:checkbox').prop('checked', false);
            $('input:checkbox').prop('disabled', false);
        });

        //*********************************

        //****************OPEN / CLOSE
        $("#sh.ADM").click(function () {
            $("tr.row.ADM:nth-child(n)").toggle();
            $("#sh.ADM i").toggleClass('bx-up-arrow-alt');
        });
        $("#sh.CDM").click(function () {
            $("tr.row.CDM:nth-child(n)").toggle();
            $("#sh.CDM i").toggleClass('bx-up-arrow-alt');
        });
        $("#sh.CRM").click(function () {
            $("tr.row.CRM:nth-child(n)").toggle();
            $("#sh.CRM i").toggleClass('bx-up-arrow-alt');
        });
        $("#sh.LOC").click(function () {
            $("tr.row.LOC:nth-child(n)").toggle();
            $("#sh.LOC i").toggleClass('bx-up-arrow-alt');
            //if ($(this).text().trim() == '') {
            //    $(this).text('-');
            //} else {
            //    $(this).text('+');
            //}
            //var x= $(this).text().trim();
            //plusminus(x);
        });
        $("#sh.LRM").click(function () {
            $("tr.row.LRM:nth-child(n)").toggle();
            $("#sh.LRM i").toggleClass('bx-up-arrow-alt');
        });
        $("#sh.QRP").click(function () {
            $("tr.row.QRP:nth-child(n)").toggle();
            $("#sh.QRP i").toggleClass('bx-up-arrow-alt');
        });
        $("#sh.RAT").click(function () {
            $("tr.row.RAT:nth-child(n)").toggle();
            $("#sh.RAT i").toggleClass('bx-up-arrow-alt');
        });
        //*********************************


        //****************CHECK All in column
        //function check all and disable
        function chkb_chkalldisable(chkClass, chk) {
            //var checkboxes = $(chkClass).closest('tr').find(':checkbox');
            //checkboxes.prop('checked', this.checked);
            $(chkClass).prop('checked', chk);
            if (chk) {
                $(chkClass).prop('disabled', true);
                //checkboxes.prop('disabled', true);
            } else {
                $(chkClass).prop('disabled', false);
                //checkboxes.prop('disabled', false);
            }
        }
        //not use
        function chkb_chkallrow(chkClass) {
            var checkboxes = $(chkClass).closest('tr').find(':checkbox');
            checkboxes.prop('checked', this.checked);
            if (this.checked) {
                checkboxes.prop('disabled', true);
            } else {
                checkboxes.prop('disabled', false);
            }
        }

        $('#ADM.columnIsSelected').click(function () {
            //$('.ADMIsSelected').prop('checked', this.checked);//example check all
            chkb_chkalldisable('.ADM.IsSelected', this.checked);
            //set check all Reports List
            if ($(this).is(":checked")) {
                //uncheck
                $('#ADM.columnList_Role').prop('checked', false);
                $('#ADM.columnView_Role').prop('checked', false);
                $('#ADM.columnExport_Role').prop('checked', false);
                //check
                $('#ADM.columnList_Role').click();
                $('#ADM.columnView_Role').click();
                $('#ADM.columnExport_Role').click();
                //disable
                chkb_chkalldisable('#ADM.columnList_Role', this.checked);
                chkb_chkalldisable('#ADM.columnView_Role', this.checked);
                chkb_chkalldisable('#ADM.columnExport_Role', this.checked);
            }
            else {
                chkb_chkalldisable('#ADM.columnList_Role', this.checked);
                chkb_chkalldisable('#ADM.columnView_Role', this.checked);
                chkb_chkalldisable('#ADM.columnExport_Role', this.checked);
                chkb_chkalldisable('.ADM.List_Role', this.checked);
                chkb_chkalldisable('.ADM.View_Role', this.checked);
                chkb_chkalldisable('.ADM.Export_Role', this.checked);
            }
        });
        $('#ADM.columnList_Role').click(function () {
            chkb_chkalldisable('.ADM.List_Role', this.checked);
        });
        $('#ADM.columnView_Role').click(function () {
