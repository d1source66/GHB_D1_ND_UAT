            </div>
        </div>
        <div class="col-md-12">
            <div class="col-md-10" style="display:flex;">
                <div class="radioPad">Position Role</div>
                @if (ViewBag.StatusRadioLst != null)
                {
                    char[] _spl = new char[] { '|' };
                    char[] _spf = new char[] { ',' };
                    string[] _arrLine = null;
                    string[] _arrField = null;
                    string Tmpstr = ViewBag.StatusRadioLst;
                    string strSel = ViewBag.Seleted;
                    _arrLine = Tmpstr.Split(_spl);
                    foreach (string str in _arrLine)
                    {
                        _arrField = str.Split(_spf);
                        if (strSel == _arrField[0].ToString())
                        {
                            <div class="radioPad">
                                <input type="radio" name="_role" class="role" value="@(_arrField[0].ToString())" checked>@(_arrField[1].ToString())
                            </div>
                        }
                        else
                        {
                            <div class="radioPad">
                                <input type="radio" name="_role" class="role" value="@(_arrField[0].ToString())">@(_arrField[1].ToString())
                            </div>
                        }
                    }
                }
                @*<div class="radioPad"><input type="radio" name="_role" class="role" value="4" id="hqAdmin">HQ Admin</div>
                    <div class="radioPad"><input type="radio" name="_role" class="role" value="5" id="branchAdmin">Branch Admin</div>
                    <div class="radioPad"><input type="radio" name="_role" class="role" value="6" id="hq">HQ</div>
                    <div class="radioPad"><input type="radio" name="_role" class="role" value="2" id="branch">Branch</div>*@
            </div>
