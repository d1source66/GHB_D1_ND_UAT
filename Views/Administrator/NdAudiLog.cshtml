<script type="text/javascript">
    $(function () {
        $('#branchInput1').select2();
        $('#departInput1').select2();
        $('#disInput1').select2();
        $('#USER_LEVEL1').select2();


        $('#branchInput2').select2();
        $('#departInput2').select2();
        $('#disInput2').select2();
        $('#USER_LEVEL2').select2();

        $('#workfunction').select2();

        $("#FrDate").datepicker({

            language: 'en-en',
            format: "dd/mm/yyyy",
            maxViewMode: 3,
            daysOfWeekHighlighted: "0,6",
            autoclose: true,
            showWeek: true,
            showOtherMonths: true,
            todayHighlight: true

        });

        $("#ToDate").datepicker({

            language: 'en-en',
            format: "dd/mm/yyyy",
            maxViewMode: 3,
            daysOfWeekHighlighted: "0,6",
            autoclose: true,
            showWeek: true,
            showOtherMonths: true,
            todayHighlight: true

        });

        $("#iconFr").click(function () {
            $("#FrDate").datepicker("show");
        });

        $("#iconTo").click(function () {
            $("#ToDate").datepicker("show");
        });

        $('#firstInput').on('input', function () {
            const maxLength = 5;
            const value = $(this).val();

            // Restrict input to numbers only
            if (value.length > maxLength) {
                $(this).val(value.slice(0, maxLength));
            }
        });
    });
</script>
