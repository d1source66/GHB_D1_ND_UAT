@section Scripts {
    <script>
        $(document).ready(function () {
            $('#select-all').click(function () {
                var isChecked = $(this).is(':checked');
                //$('input[type="checkbox"]').each(function () {
                //    //$(this).prop('checked', isChecked);
                //    $('.item-checkbox').prop('checked', isChecked);
                //});
                $("#searchTable tr:visible .item-checkbox").prop('checked', isChecked);
            });
        });
    </script>
    <script>
        $(document).ready(function () {
            //$("#searchInput").on("keyup", function () {
            //    var value = $(this).val().toLowerCase();
            //    $("#searchTable tr").filter(function () {
            //        $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
            //    });
            //});
        });

        function cfD() {
            //var btn = $(this).attr('Value');
            var data = "";
            var x = confirm("คุณต้องการลบ Config นี้รึเปล่า")
            if (x) {
                return true;
            } else {
                data = { cmdButton: "NO" };
                var url = '@Url.Action("NdUserAttrib", "Administrator")';
                // method POST -> '$.post()'
                $.post(url, data, function (result) {
                    window.location = '@Url.Action("NdMainUserAttrib", "Administrator")';
                    @*if (result.status == "success") {
                        window.location = '@Url.Action("NdUserAttrib", "Administrator")';
                    }*@
                });
                return false;
            }
        }
    </script>

}
