@using (Html.BeginForm("NdCreateUserTrasnLdap", "Administrator", FormMethod.Post, new { autocomplete = "off", @style = "padding-bottom: 24%;" }))
{
    <div class="col-md-12 setNav">
        <a name="" class="setNavFont headPath" href="@Url.Action("Index","Administrator")"><i class="fa fa-home fa-color-orange"></i>หน้าหลัก</a>
        <label class="setNavFont"> / </label>
        <a name="" class="setNavFont headPath" href="@Url.Action("NdUserTransfer","Administrator")"><i class="fa fa-home fa-color-orange"></i> User Transfer </a>
        <label class="setNavFont"> / </label>
        <label class="setNavFont"> Create User </label>
    </div>
    <div class="setPage ">
        <div class="row g-3 formColor">
            <div class="col-md-12" style="border-bottom: 1px solid #e0e0e0;">
                <div class="col-md-8">
                    <label class="form-label labelForm">Create User Transfer</label>
                </div>
                <div class="col-md-2"></div>
                <div class="col-md-2 setButton1">
                    &nbsp;
                </div>
            </div>
            <div class="col-md-12">&nbsp;</div>
            <div class="col-md-12">
                <div class="col-md-2"></div>
                <div class="col-md-8" style="display: flex;  margin-left: 24px;">
                    @Html.ValidationSummary(true, "", new { @class = "text-danger removeBullet loginWrong validfont", style = "" })
                </div>
                <div class="col-md-2"></div>
            </div>
            <div class="col-md-12" style="display: flex; align-items: center;">
                <div class="col-md-6" style="display: flex; justify-content: flex-end;">
                    <label class="form-label labelCss" for="USER_EMP_CODE">รหัสพนักงาน*</label>&nbsp;
                    @*<input type="text" class="form-control txtinput" id="usernameInput" style="width:50%;">*@
                    <input type="number" class="form-control rounded-lg" id="USER_EMP_CODE" placeholder="Employee code" name="USER_EMP_CODE" value="@ViewBag.USER_EMP_CODE">
                </div>
                <div class="col-md-6">
                    <button id="btnVerifyUser" type="submit" class="btn btn-ghb-primary" data-toggle="tooltip" name="cmdButton" title="Verify User" value="VerifyUser" style="padding: 6px 12px; width: 15%;">ค้นหา</button>
                    <button id="btnClear" type="submit" class="btn btn-ghb-primary" data-toggle="tooltip" name="cmdButton" title="Verify User" value="Reset" style="border: unset; padding: 6px 12px; width: 15%;">เคลียร์ค่า</button>
                </div>
            </div>
            <div class="col-md-12">&nbsp;</div>
        </div>
    </div>


}
