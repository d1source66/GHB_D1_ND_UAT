@model List<GHB_D1.Models.UserModels>
@{
    ViewBag.Title = "MenuView";
    Layout = "~/Views/Shared/_LayoutV3.cshtml";
}
<link href="~/Content/bootstrap.min.css" rel="stylesheet" />
<script src="~/Scripts/jquery-dataTable/jquery.min.js"></script>
<script src="~/Scripts/datatables/jquery.dataTables.min.js"></script>
<script src="~/Scripts/datatables-bs4/js/dataTables.bootstrap4.min.js"></script>
<link href="~/Scripts/datatables-bs4/css/dataTables.bootstrap4.min.css" rel="stylesheet" />
<style>

    #tbl1 {
        border-collapse: separate;
        border-spacing: 0;
    }

    td {
        border: solid 1px #000;
        border-style: none solid solid none;
        padding: 10px;
    }

    tr:first-child td:first-child {
        border-top-left-radius: 10px;
    }

    tr:first-child td:last-child {
        border-top-right-radius: 10px;
    }

    tr:last-child td:first-child {
        border-bottom-left-radius: 10px;
    }

    tr:last-child td:last-child {
        border-bottom-right-radius: 10px;
    }

    tr:first-child td {
        border-top-style: solid;
    }

    tr td:first-child {
        border-left-style: solid;
    }

    .setPage {
        padding: 95px 0px 0px 118px;
    }

    .formColor {
        background-color: #ffffff;
        border-radius: 12px;
    }

    .setButton {
        display: flex;
        flex-direction: row;
        padding: 20px 0px 0px 0px;
        color: #ff850c;
    }

    .setButtonFont {
        color: #fff;
        background-color: #ff850c;
        border-color: #ff850c;
    }

    .button[type=submit] {
        width: 68% !important;
    }

    .btn-primary {
        color: #fff !important;
        background-color: #ff850c !important;
        border-color: #ff850c !important;
        width: 68% !important;
    }

        .btn-primary:hover {
            color: #fff !important;
            background-color: #ff850c !important;
            border-color: #ff850c !important;
            width: 68% !important;
        }

        .btn-primary:focus {
            color: #fff !important;
            background-color: #ff850c !important;
            border-color: #ff850c !important;
            width: 68% !important;
        }

        .btn-primary:active {
            color: #fff !important;
            background-color: #ff850c !important;
            border-color: #ff850c !important;
            width: 68% !important;
        }

            .btn-primary:active:hover {
                color: #fff !important;
                background-color: #ff850c !important;
                border-color: #ff850c !important;
                width: 68% !important;
            }

            .btn-primary:active:active {
                color: #fff !important;
                background-color: #ff850c !important;
                border-color: #ff850c !important;
                width: 68% !important;
            }

    .mg {
        margin: 0px 5px;
    }

    .roleSet {
        display: flex;
        flex-direction: row;
        flex-wrap: nowrap;
        align-items: center;
    }

    .newNav {
        background-color: unset !important;
        background: unset !important;
        color: #ff850c;
    }

        .newNav:hover {
            background-color: unset !important;
            background: unset !important;
            color: red;
        }

    .formColor {
        background-color: #ffffff;
        border-radius: 12px;
    }
</style>
@using (Html.BeginForm("RoleManage", "Administrator", FormMethod.Post))
{
    <div class="setPage">
        @*<h2>MenuView</h2>*@
        <div class="row g-3 formColor">

            <div class="col-md-12" style="border-bottom: 1px solid #e0e0e0;">
                <div class="col-md-8">
                    <label class="form-label" style="font-size: 28px; padding: 20px 0px 0px 0px; color: #ff850c;">Role Management</label>
                </div>
                <div class="col-md-4 setButton">
                    <button type="submit" class="btn btn-primary mg" id="create" name="cmdButton" value="Add">สร้าง</button>
                    <button type="submit" class="btn btn-primary mg" id="exExcel">Export Excel</button>
                    <button type="submit" class="btn btn-primary mg" id="exCsv">Export CSV</button>
                </div>
            </div>
            <div class="col-md-12">&nbsp;</div>
            <div class="col-md-12">
                <div class="col-md-4 roleSet ">
                    <label class="form-label" for="searchInput" style="font-size: 12px; color: #ff850c;">Role</label>
                    <input type="text" class="form-control" id="searchInput">
                    <button type="submit" class="btn btn-primary mg" style="height:35px;">ค้นหา</button>
                </div>
                <div class="col-md-4">
                    &nbsp;
                </div>
                <div class="col-md-4">
                    &nbsp;
                </div>
            </div>
            <div style="padding:18px;">
                <div class="card-body">
                    <table class="table table-bordered table-striped" id="tbl1">
                        <thead>
                            <tr>
                                <th style="text-align:center;vertical-align:top;" width="10%" class="ghb-background-color">ชื่อผู้ใช้</th>
                                <th style="text-align:center;vertical-align:top;" width="15%" class="ghb-background-color">ระดับ(Role)</th>
                                <th style="text-align:center;vertical-align:top;" width="30%" class="ghb-background-color">ชื่อ นามสกุล</th>
                                <th style="text-align:center;vertical-align:top;" width="5%" class="ghb-background-color">Modify</th>
                            </tr>
                        </thead>
                        <tbody id="searchTable">
                            @for (int i = 0; i < Model.Count; i++)
                            {
                                <tr>
                                    <td style="text-align: left;">@Html.DisplayFor(m => Model[i].USER_LOGIN)</td>
                                    <td style="text-align: center;">@Html.DisplayFor(m => Model[i].User_Role_Level)</td>
                                    <td style="text-align: left;">@Html.DisplayFor(m => Model[i].USER_FIRSTNAME) @Html.DisplayFor(m => Model[i].USER_LASTNAME)</td>
                                    <td style="text-align: center;">
                                        <div href="#" class="nav_link submenu_item newNav">
                                            <span class="navlink_icon newNav">
                                                <i class="bx bx-edit"></i>
                                            </span>
                                        </div>
                                        @*<button id="btnEdit" type="submit" class="btn btn-ghb-primary" data-toggle="tooltip" name="cmdButton" title="Edit" value="Edit|@Model[i].USER_ID">EDIT</button>*@
                                    </td>
                                    @Html.HiddenFor(m => Model[i].USER_ID)
                                    @Html.HiddenFor(m => Model[i].USER_LOGIN)
                                    @Html.HiddenFor(m => Model[i].USER_LEVEL)
                                    @Html.HiddenFor(m => Model[i].User_Role_Level)
                                    @Html.HiddenFor(m => Model[i].IS_ACTIVE)
                                    @Html.HiddenFor(m => Model[i].User_Branch)

                                </tr>
                            }
                        </tbody>
                    </table>
                    @*<div class="card-body" style="display:none;">
                            <button type="button" class="btn btn-default" data-toggle="modal" data-target="#modal-default">
                                Save
                                <div class="overlay"><i class="fas fa-3x fa-sync-alt fa-spin"></i><div class="text-bold pt-2">Loading...</div></div>
                            </button>
                        </div>*@
                </div>
            </div>
            <div style="padding:15px; display:none;">
                <div class="col-md-6">
                    <label for="inputEmail4" class="form-label">Email</label>
                    <input type="email" class="form-control" id="inputEmail4">
                </div>
                <div class="col-md-6">
                    <label for="inputPassword4" class="form-label">Password</label>
                    <input type="password" class="form-control" id="inputPassword4">
                </div>
                <div class="col-12">
                    <label for="inputAddress" class="form-label">Address</label>
                    <input type="text" class="form-control" id="inputAddress" placeholder="1234 Main St">
                </div>
                <div class="col-12">
                    <label for="inputAddress2" class="form-label">Address 2</label>
                    <input type="text" class="form-control" id="inputAddress2" placeholder="Apartment, studio, or floor">
                </div>
                <div class="col-md-6">
                    <label for="inputCity" class="form-label">City</label>
                    <input type="text" class="form-control" id="inputCity">
                </div>
                <div class="col-md-4">
                    <label for="inputState" class="form-label">State</label>
                    <select id="inputState" class="form-select">
                        <option selected>Choose...</option>
                        <option>...</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label for="inputZip" class="form-label">Zip</label>
                    <input type="text" class="form-control" id="inputZip">
                </div>
                <div class="col-12">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="gridCheck">
                        <label class="form-check-label" for="gridCheck">
                            Check me out
                        </label>
                    </div>
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-primary">Sign in</button>
                </div>
            </div>
            @*</form>
                <form class="row g-3 formColor">*@
            <div class="form-group" style=" display: none;">
                <label for="exampleInputEmail1">Email address</label>
                <input type="email" class="form-control" id="exampleInputEmail1" aria-describedby="emailHelp" placeholder="Enter email">
                <small id="emailHelp" class="form-text text-muted">We'll never share your email with anyone else.</small>
            </div>
            <div class="form-group" style=" display: none;">
                <label for="exampleInputPassword1">Password</label>
                <input type="password" class="form-control" id="exampleInputPassword1" placeholder="Password">
            </div>
            <div class="form-check" style=" display: none;">
                <input type="checkbox" class="form-check-input" id="exampleCheck1">
                <label class="form-check-label" for="exampleCheck1">Check me out</label>
            </div>
            <button type="submit" class="btn btn-primary" style=" display: none;">Submit</button>
        </div>
    </div>
}
    <script>
        $(function () {


            $("#searchInput").on("keyup", function () {
                var value = $(this).val().toLowerCase();
                $("#searchTable tr").filter(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });



            $("#tbl1").DataTable({
                "responsive": true, "lengthChange": false, "autoWidth": false, searching: false,
                //"oLanguage": {
                //    "sSearch": "Role"
                //}
            });

        });
    </script>
