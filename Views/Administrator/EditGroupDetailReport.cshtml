
@{
    ViewBag.Title = "EditGroupDetailReport";
    Layout = "~/Views/Shared/_LayoutV2.cshtml";
}

<script type="text/javascript">
    $(function () {
        $('#GroupNo').select2();
        $('#loading').hide();
        $("#btnSave").click(function () {
            $('#loading').show();
        });
    });
</script>
@if (ViewBag.Message != null)
{
    <script type="text/javascript">
            $(function () {
                alert("@ViewBag.Message");
            });
    </script>
}

<style>
    .navbar-inverse {
        background-color: #ff850c;
        border-color: #ff850c;
        min-height: 65px;
    }

        .navbar-inverse .navbar-brand {
            color: #ffffff;
        }

        .navbar-inverse .navbar-nav > li > a {
            color: #ffffff;
        }

    .lbcolor {
        color: orange;
    }

    hr {
        border-top: 1px solid orange !important;
    }

    #loading {
        position: fixed;
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        opacity: 0.7;
        background-color: #fff;
        z-index: 99;
    }

    #loading-image {
        z-index: 100;
    }
</style>
<div id="loading">
    <img id="loading-image" src="~/images/Spinner-5.gif" alt="Loading..." />
</div>
<div class="row">
    <div class="col-2">
        <table>
            <tr>
                <td colspan="2">
                    <h2 class="header-topic" style="color: orange; margin-bottom: 0px;">Administrator</h2>
                    <h5 class="header-topic" style="color: orange; margin-left: 70px; margin-top: 0px;">EDIT GROUP DETAIL REPORT</h5>
                </td>
            </tr>
        </table>
    </div>
</div>



@using (Html.BeginForm("EditGroupDetailReport", "Administrator", FormMethod.Post))
{
    @Html.Hidden("ID", ViewBag.ID as string)
<div class="container">
    <div class="row">
        <div class="col-lg-2">
            <label class="ghbFont-color">รหัสกลุ่ม&nbsp;</label>&nbsp;&nbsp;
            @*@Html.TextBox("GroupNo", ViewBag.GroupNo as string, new { @class = "form-control rounded-lg", maxlength = "30" })*@
            <select name="GroupNo" id="GroupNo" class="form-control w-100 rounded-lg">
                @{
                    <option value="All">โปรดเลือก</option>
                    if (ViewBag.CurrentGroupReportList != "" && ViewBag.CurrentGroupReportList != "All")
                    {
                        char[] _spl = new char[] { '|' };
                        char[] _spf = new char[] { ',' };
                        string[] _arrLine = null;
                        string[] _arrField = null;
                        string Tmpstr = ViewBag.CurrentGroupReportList;
                        string strSel = ViewBag.GroupNo;
                        _arrLine = Tmpstr.Split(_spl);
                        foreach (string str in _arrLine)
                        {
                            _arrField = str.Split(_spf);
                            if (strSel == _arrField[0].ToString())
                            {
                                <option selected="selected" value="@(_arrField[0].ToString())">@(_arrField[1].ToString())</option>
                            }
                            else
                            {
                                <option value="@(_arrField[0].ToString())">@(_arrField[1].ToString())</option>
                            }
                        }
                    }
                }
            </select>
        </div>
    </div>
    <div class="row">
        <div class="col-lg-2">
            <label class="ghbFont-color">รหัสรายงาน&nbsp;</label>&nbsp;&nbsp;
            @Html.TextBox("ReportNo", ViewBag.ReportNo as string, new { @class = "form-control rounded-lg", maxlength = "30" })
        </div>
    </div>
    <div class="row">
        <div class="col-lg-2">
            <label class="ghbFont-color">ชื่อรายงาน&nbsp;</label>&nbsp;&nbsp;
            @Html.TextBox("ReportName", ViewBag.ReportName as string, new { @class = "form-control rounded-lg", maxlength = "50" })
        </div>
    </div>
    <div class="row">
        <div class="col-lg-2">
            <label class="ghbFont-color">สถานะ&nbsp;</label>&nbsp;&nbsp;
            @Html.CheckBox("Active", (bool)ViewBag.Active, new { @class = "form-control rounded-lg" })
        </div>
    </div>
    <div class="row">
        <div class="col-lg-2">
            <button id="btnSave" type="submit" class="btn btn-ghb-primary" data-toggle="tooltip" name="cmdButton" title="Save" value="Save" style="margin-top: 20px;margin-bottom:20px;">SAVE</button>
            <button id="btnCancel" type="submit" class="btn btn-ghb-primary" data-toggle="tooltip" name="cmdButton" title="Cancel" value="Cancel" style="margin-top: 20px; margin-bottom: 20px;">CANCEL</button>
        </div>
    </div>
</div>
}
