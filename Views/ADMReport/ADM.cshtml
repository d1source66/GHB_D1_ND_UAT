<script src="~/Scripts/bootstrap-datepicker-thai/js/locales/bootstrap-datepicker.th.js"></script>
<script>
    $().ready(function () {
        $("#FrDate").datepicker({

            language: 'en-en',
            format: "dd/mm/yyyy",
            maxViewMode: 3,
            daysOfWeekHighlighted: "0,6",
            autoclose: true,
            showWeek: true,
            showOtherMonths: true,
            todayHighlight: true

        });

        $("#ToDate").datepicker({

            language: 'en-en',
            format: "dd/mm/yyyy",
            maxViewMode: 3,
            daysOfWeekHighlighted: "0,6",
            autoclose: true,
            showWeek: true,
            showOtherMonths: true,
            todayHighlight: true

        });

        $("#iconFr").click(function () {
            $("#FrDate").datepicker("show");
        });

        $("#iconTo").click(function () {
            $("#ToDate").datepicker("show");
        });

        $("#FrDate1").change(function () {
            var inputStartDate = $("#FrDate").val();
            var [Sday, Smonth, Syear] = inputStartDate.split('/');
            var formattedStarDate = new Date(`${Smonth}/${Sday}/${Syear}`);
            var startDate = new Date(formattedStarDate);

            var inputEndDate = $("#ToDate").val();
            var [day, month, year] = inputEndDate.split('/');
            var formattedEndDate = new Date(`${month}/${day}/${year}`);
            var endDate = new Date(formattedEndDate);

            var timeDiff = endDate.getTime() - startDate.getTime();
            var dayDiff = timeDiff / (1000 * 3600 * 24);

            if (dayDiff > 30) {
                alert("จำนวนวันต้องไม่เกิน 30 วัน")
                var yesterday = new Date();
                yesterday.setDate(yesterday.getDate() - 1);
                $("#FrDate").datepicker("setDate", yesterday);
                $("#FrDate").datepicker("refresh");
            } else if (dayDiff < 0) {
                alert("วันเริ่มต้องมาก่อนวันสิ้นสุด")
                var yesterday = new Date();
                yesterday.setDate(yesterday.getDate() - 1);
                $("#FrDate").datepicker("setDate", yesterday);
                $("#FrDate").datepicker("refresh");
            } else {
                //alert("Dates are valid. Difference: " + dayDiff + " days.")
            }

        });

        $("#ToDate1").change(function () {
            var inputStartDate = $("#FrDate").val();
            var [Sday, Smonth, Syear] = inputStartDate.split('/');
            var formattedStarDate = new Date(`${Smonth}/${Sday}/${Syear}`);
            var startDate = new Date(formattedStarDate);

            var inputEndDate = $("#ToDate").val();
            var [day, month, year] = inputEndDate.split('/');
            var formattedEndDate = new Date(`${month}/${day}/${year}`);
            var endDate = new Date(formattedEndDate);

            var timeDiff = endDate.getTime() - startDate.getTime();
            var dayDiff = timeDiff / (1000 * 3600 * 24);

            if (dayDiff > 30) {
                alert("จำนวนวันต้องไม่เกิน 30 วัน")
                var yesterday = new Date();
                yesterday.setDate(yesterday.getDate() - 1);
                $("#ToDate").datepicker("setDate", yesterday);
                /*$("#ToDate").datepicker("refresh");*/
            } else if (dayDiff < 0) {
                alert("วันเริ่มต้องมาก่อนวันสิ้นสุด")
                var yesterday = new Date();
                yesterday.setDate(yesterday.getDate() - 1);
                $("#ToDate").datepicker("setDate", yesterday);
                //$("#ToDate").datepicker("refresh");
            } else {
                //alert("Dates are valid. Difference: " + dayDiff + " days.")
            }
        });

        $("#T_DATE").change(function () {
            let d = $(this).val();
            var b = $("#T_DATE").val();
            $("#displayDate").text(d);
            $("#T_DATE").val(d);
            $("#msg").hide();
        })

        $("#searchInput").on("keyup", function () {
            var value = $(this).val().toLowerCase();
            $("#searchTable tr").filter(function () {
                $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
            });
        });

        $("#cmdClose").on("click", function () {
            $("#msg").hide();
        });

        $('#SOLCODE').on('input', function () {
            const maxLength = 3;
            const value = $(this).val();

            // Restrict input to numbers only
            if (value.length > maxLength) {
                $(this).val(value.slice(0, maxLength));
            }
        });

    })
</script>


